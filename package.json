{
  "name": "voilavoila-tools",
  "version": "1.0.0",
  "description": "Plateforme unifiée QR, Signatures, VCards — Voilà Voilà",
  "main": "src/app.js",
  "scripts": {
    "postinstall": "npx prisma generate",
    "dev": "concurrently \"node --watch src/app.js\" \"npx tailwindcss -i ./src/views/input.css -o ./public/css/app.css --watch\"",
    "build:css": "npx tailwindcss -i ./src/views/input.css -o ./public/css/app.css --minify",
    "start": "node src/app.js",
    "db:push": "npx prisma db push",
    "db:seed": "node prisma/seed.js",
    "db:studio": "npx prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^5.10.0",
    "bcryptjs": "^2.4.3",
    "connect-flash": "^0.1.1",
    "@quixo3/prisma-session-store": "^3.1.19",
    "csrf-csrf": "^3.0.0",
    "ejs": "^3.1.9",
    "express": "^4.18.3",
    "express-rate-limit": "^7.2.0",
    "express-session": "^1.18.0",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "method-override": "^3.0.0",
    "multer": "^1.4.5-lts.1",
    "passport": "^0.7.0",
    "passport-local": "^1.0.0",
    "slugify": "^1.6.6",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "prisma": "^5.10.0",
    "tailwindcss": "^3.4.1"
  }
}
