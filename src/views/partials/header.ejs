<header style="flex-shrink: 0; background: var(--bg); border-bottom: 1px solid var(--border); padding: 0 20px; height: 52px; display: flex; align-items: center; justify-content: space-between; gap: 16px;">

  <!-- Burger mobile -->
  <button @click="sidebarOpen = true" class="lg:hidden" style="color: var(--text-muted); padding: 4px;">
    <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M4 6h16M4 12h16M4 18h16"/>
    </svg>
  </button>

  <!-- Breadcrumb -->
  <nav style="display: flex; align-items: center; gap: 6px; font-size: 12px; min-width: 0; flex: 1;">
    <a href="/dashboard" style="color: var(--text-muted); text-decoration: none; transition: color 120ms; flex-shrink: 0;"
       onmouseover="this.style.color='var(--text)'" onmouseout="this.style.color='var(--text-muted)'">
      Accueil
    </a>
    <% if (typeof breadcrumb !== 'undefined' && breadcrumb) { %>
      <% breadcrumb.forEach((crumb, i) => { %>
        <span style="color: var(--text-dim);">/</span>
        <% if (i === breadcrumb.length - 1) { %>
          <span style="color: var(--text); font-weight: 500; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;"><%= crumb.label %></span>
        <% } else { %>
          <a href="<%= crumb.href %>" style="color: var(--text-muted); text-decoration: none; transition: color 120ms; flex-shrink: 0;"
             onmouseover="this.style.color='var(--text)'" onmouseout="this.style.color='var(--text-muted)'"><%= crumb.label %></a>
        <% } %>
      <% }) %>
    <% } else { %>
      <span style="color: var(--text-dim);">/</span>
      <span style="color: var(--text); font-weight: 500; font-family: 'Syne', sans-serif; font-size: 13px;"><%= title %></span>
    <% } %>
  </nav>

  <!-- User dropdown -->
  <div style="flex-shrink: 0; position: relative;" x-data="{ open: false }">
    <button @click="open = !open"
      style="display: flex; align-items: center; gap: 8px; padding: 4px 8px 4px 4px; border-radius: 6px; border: 1px solid transparent; background: transparent; cursor: pointer; transition: all 120ms;"
      :style="open ? 'border-color: var(--border-mid); background: var(--surface-2);' : ''"
      onmouseover="this.style.borderColor='var(--border)'; this.style.background='var(--surface-2)'"
      onmouseout="if (!$data.open) { this.style.borderColor='transparent'; this.style.background='transparent'; }">
      <div style="width: 24px; height: 24px; border-radius: 50%; background: var(--accent-dim); border: 1px solid rgba(0,0,255,0.2); display: flex; align-items: center; justify-content: center; font-family: 'Syne', sans-serif; font-size: 10px; font-weight: 700; color: var(--accent);">
        <%= user?.name?.[0]?.toUpperCase() || 'U' %>
      </div>
      <span class="hidden sm:block" style="font-size: 12px; font-weight: 500; color: var(--text); max-width: 120px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;"><%= user?.name %></span>
      <svg width="12" height="12" fill="none" stroke="var(--text-muted)" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
      </svg>
    </button>

    <div x-cloak x-show="open" @click.outside="open = false"
      x-transition:enter="transition ease-out duration-100"
      x-transition:enter-start="opacity-0 translate-y-1"
      x-transition:enter-end="opacity-100 translate-y-0"
      style="position: absolute; right: 0; top: calc(100% + 6px); width: 200px; border: 1px solid var(--border-mid); border-radius: 8px; background: var(--surface-2); overflow: hidden; z-index: 50; box-shadow: 0 8px 32px rgba(0,0,0,0.6);">
      <div style="padding: 10px 12px; border-bottom: 1px solid var(--border);">
        <div style="font-size: 12px; font-weight: 500; color: var(--text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis;"><%= user?.name %></div>
        <div style="font-size: 11px; color: var(--text-muted); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin-top: 1px;"><%= user?.email %></div>
      </div>
      <a href="/auth/logout"
        style="display: flex; align-items: center; gap: 8px; padding: 9px 12px; font-size: 12px; color: #f87171; text-decoration: none; transition: background 100ms;"
        onmouseover="this.style.background='rgba(239,68,68,0.08)'" onmouseout="this.style.background='transparent'">
        <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
        </svg>
        Déconnexion
      </a>
    </div>
  </div>
</header>
