<%
  const orgSlug = (typeof currentOrg !== 'undefined' && currentOrg) ? currentOrg.slug : null;
%>

<!-- Logo -->
<div class="flex items-center px-5 py-5 flex-shrink-0">
  <img src="/img/voilavoila-logo-blanc.webp" alt="Voilà Voilà Tools" class="h-7 object-contain">
</div>

<!-- Switcher organisation -->
<% if (userOrgs && userOrgs.length > 0 && orgSlug) { %>
<div class="px-4 pb-3 flex-shrink-0" x-data="{ open: false }">
  <button @click="open = !open" class="w-full flex items-center justify-between text-left px-3 py-2 rounded-lg hover:bg-white/10 transition-colors">
    <div class="flex items-center gap-2 min-w-0">
      <div class="w-6 h-6 rounded-md bg-white/20 flex-shrink-0 flex items-center justify-center text-white text-xs font-bold">
        <%= (currentOrg?.name || 'O')[0].toUpperCase() %>
      </div>
      <span class="text-sm font-medium text-white/80 truncate"><%= currentOrg?.name || 'Organisation' %></span>
    </div>
    <svg class="w-4 h-4 text-white/40 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l4-4 4 4m0 6l-4 4-4-4"/>
    </svg>
  </button>
  <div x-show="open" @click.outside="open = false" x-transition
       class="mt-1 bg-white/10 backdrop-blur-sm border border-white/20 rounded-lg overflow-hidden z-10 relative">
    <% userOrgs.forEach(org => { %>
    <a href="/o/<%= org.slug %>/qr"
       class="flex items-center gap-2 px-3 py-2 text-sm hover:bg-white/10 transition-colors <%= org.slug === orgSlug ? 'text-white font-medium' : 'text-white/70' %>">
      <div class="w-5 h-5 rounded flex-shrink-0 flex items-center justify-center bg-white/20 text-white text-xs font-bold">
        <%= org.name[0].toUpperCase() %>
      </div>
      <span class="truncate"><%= org.name %></span>
      <% if (org.slug === orgSlug) { %>
      <svg class="w-4 h-4 ml-auto text-white/60" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
      </svg>
      <% } %>
    </a>
    <% }) %>
  </div>
</div>
<% } %>

<!-- Navigation principale -->
<nav class="flex-1 px-3 py-2 overflow-y-auto">
  <p class="vv-nav-section mb-3">Outils</p>

  <a href="<%= orgSlug ? `/o/${orgSlug}/qr` : '#' %>"
     class="vv-nav-item <%= currentPath && currentPath.includes('/qr') ? 'active' : '' %>">
    <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v1m6 11h2m-6 0h-2v4m0-11v3m0 0h.01M12 12h4.01M16 20h4M4 12h4m12 0h.01M5 8h2a1 1 0 001-1V5a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1zm12 0h2a1 1 0 001-1V5a1 1 0 00-1-1h-2a1 1 0 00-1 1v2a1 1 0 001 1zM5 20h2a1 1 0 001-1v-2a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1z"/>
    </svg>
    QR Codes
  </a>

  <a href="<%= orgSlug ? `/o/${orgSlug}/signatures` : '#' %>"
     class="vv-nav-item <%= currentPath && currentPath.includes('/signatures') ? 'active' : '' %>">
    <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
    </svg>
    Signatures Email
  </a>

  <a href="<%= orgSlug ? `/o/${orgSlug}/vcards` : '#' %>"
     class="vv-nav-item <%= currentPath && currentPath.includes('/vcards') ? 'active' : '' %>">
    <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V8a2 2 0 00-2-2h-5m-4 0V5a2 2 0 114 0v1m-4 0a2 2 0 104 0m-5 8a2 2 0 100-4 2 2 0 000 4zm0 0c1.306 0 2.417.835 2.83 2M9 14a3.001 3.001 0 00-2.83 2M15 11h3m-3 4h2"/>
    </svg>
    VCards
  </a>

  <% if (orgSlug) { %>
  <div class="mt-5">
    <p class="vv-nav-section mb-3">Organisation</p>
    <a href="/o/<%= orgSlug %>/settings"
       class="vv-nav-item <%= currentPath && currentPath.includes('/settings') ? 'active' : '' %>">
      <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
      </svg>
      Paramètres
    </a>
    <a href="/o/<%= orgSlug %>/members"
       class="vv-nav-item <%= currentPath && currentPath.includes('/members') ? 'active' : '' %>">
      <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/>
      </svg>
      Membres
    </a>
  </div>
  <% } %>
</nav>

<!-- Footer sidebar : user -->
<div class="border-t border-white/10 p-4 flex-shrink-0">
  <div class="flex items-center gap-3">
    <div class="w-8 h-8 rounded-full bg-white/20 flex-shrink-0 flex items-center justify-center text-white text-sm font-bold">
      <%= user?.name?.[0]?.toUpperCase() || 'U' %>
    </div>
    <div class="min-w-0 flex-1">
      <p class="text-sm font-medium text-white truncate"><%= user?.name || '' %></p>
      <p class="text-xs text-white/50 truncate"><%= user?.email || '' %></p>
    </div>
    <a href="/auth/logout" title="Déconnexion" class="text-white/40 hover:text-white/80 transition-colors flex-shrink-0">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
      </svg>
    </a>
  </div>
</div>
