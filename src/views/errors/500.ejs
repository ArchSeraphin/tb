<!DOCTYPE html>
<html lang="fr" class="h-full bg-gray-50">
<head>
  <meta charset="UTF-8"><link rel="icon" href="/voilavoila-favicon.webp" type="image/webp"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Erreur — Voilà Voilà Tools</title>
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@600;700;800&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/app.css">
</head>
<body class="h-full flex items-center justify-center p-4">
  <div class="text-center">
    <p class="text-6xl font-black text-red-100 mb-4">500</p>
    <h1 class="text-2xl font-bold text-gray-900 mb-2">Erreur serveur</h1>
    <p class="text-gray-500 mb-6">Une erreur inattendue s'est produite. Notre équipe a été notifiée.</p>
    <% if (error && error.message) { %>
    <pre class="text-xs text-left bg-gray-100 p-4 rounded-lg mb-6 max-w-lg mx-auto overflow-auto"><%= error.message %></pre>
    <% } %>
    <a href="/" class="btn-primary">Retour à l'accueil</a>
  </div>
</body>
</html>
