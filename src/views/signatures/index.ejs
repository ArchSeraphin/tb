<!DOCTYPE html>
<html lang="fr" class="h-full bg-gray-50">
<head>
  <meta charset="UTF-8"><link rel="icon" href="/voilavoila-favicon.webp" type="image/webp"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Signatures Email — Voilà Voilà Tools</title>
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@600;700;800&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/app.css">
  <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.14.1/dist/cdn.min.js"></script>
  <script src="https://unpkg.com/htmx.org@2.0.0/dist/htmx.min.js"></script>
</head>
<body class="h-full" x-data="{ sidebarOpen: false }">
<div id="htmx-progress"></div>
<div class="flex h-full">
  <div x-cloak x-show="sidebarOpen" @click="sidebarOpen=false" class="fixed inset-0 bg-gray-900/50 z-20 lg:hidden"></div>
  <aside class="fixed inset-y-0 left-0 z-30 w-64 vv-sidebar flex flex-col transition-transform duration-300 lg:translate-x-0 lg:static lg:flex" :class="sidebarOpen ? 'translate-x-0' : '-translate-x-full'">
    <%- include('../partials/sidebar') %>
  </aside>
  <div class="flex-1 flex flex-col min-w-0 overflow-hidden">
    <%- include('../partials/header') %>
    <main class="flex-1 overflow-y-auto p-6">
      <%- include('../partials/flash') %>

      <!-- En-tête + CTA -->
      <div class="flex items-center justify-between mb-6">
        <div>
          <h1 class="text-2xl font-bold text-gray-900">Signatures Email</h1>
          <p class="text-sm text-gray-500 mt-0.5"><%= signatures.length %> signature<%= signatures.length > 1 ? 's' : '' %></p>
        </div>
        <a href="/o/<%= currentOrg.slug %>/signatures/create" class="btn-primary">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
          Nouvelle Signature
        </a>
      </div>

      <% if (signatures.length === 0) { %>
      <!-- Empty state -->
      <div class="card p-12 text-center">
        <div class="w-16 h-16 bg-brand-50 rounded-full flex items-center justify-center mx-auto mb-4">
          <svg class="w-8 h-8 text-brand-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-gray-900 mb-2">Aucune signature</h3>
        <p class="text-sm text-gray-500 mb-6">Créez votre première signature email professionnelle.</p>
        <a href="/o/<%= currentOrg.slug %>/signatures/create" class="btn-primary">Créer ma première signature</a>
      </div>

      <% } else { %>
      <!-- Tableau -->
      <div class="card overflow-hidden">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-gray-100 bg-gray-50">
              <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Nom</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider hidden md:table-cell">Template</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider hidden lg:table-cell">Créé par</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider hidden lg:table-cell">Date</th>
              <th class="px-4 py-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-50">
            <% signatures.forEach(sig => { %>
            <tr class="hover:bg-gray-50 transition-colors" id="sig-row-<%= sig.id %>">
              <td class="px-4 py-3">
                <div class="flex items-center gap-3">
                  <div class="w-8 h-8 bg-brand-50 rounded-lg flex-shrink-0 flex items-center justify-center">
                    <svg class="w-4 h-4 text-brand-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                    </svg>
                  </div>
                  <div>
                    <p class="font-medium text-gray-900"><%= sig.name %></p>
                    <p class="text-xs text-gray-400"><%= sig.slug %></p>
                  </div>
                </div>
              </td>
              <td class="px-4 py-3 hidden md:table-cell">
                <% if (sig.template === 'classic') { %>
                  <span class="badge badge-blue">Classique</span>
                <% } else if (sig.template === 'horizontal') { %>
                  <span class="badge badge-green">Horizontal</span>
                <% } else if (sig.template === 'header') { %>
                  <span class="badge badge-gray">Header</span>
                <% } else { %>
                  <span class="badge badge-gray"><%= sig.template %></span>
                <% } %>
              </td>
              <td class="px-4 py-3 hidden lg:table-cell">
                <span class="text-gray-600"><%= sig.identity?.name || '—' %></span>
              </td>
              <td class="px-4 py-3 hidden lg:table-cell">
                <span class="text-gray-400 text-xs"><%= new Date(sig.createdAt).toLocaleDateString('fr-FR') %></span>
              </td>
              <td class="px-4 py-3 text-right">
                <div class="flex items-center justify-end gap-2">
                  <a href="/o/<%= currentOrg.slug %>/signatures/<%= sig.id %>/edit"
                     class="text-gray-400 hover:text-brand-600 transition-colors" title="Modifier">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                  </a>
                  <button
                    hx-delete="/o/<%= currentOrg.slug %>/signatures/<%= sig.id %>"
                    hx-target="#sig-row-<%= sig.id %>"
                    hx-swap="outerHTML swap:300ms"
                    hx-confirm="Supprimer la signature « <%= sig.name %> » ?"
                    class="text-gray-400 hover:text-red-500 transition-colors" title="Supprimer">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                  </button>
                </div>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <% } %>

    </main>
  </div>
</div>
<%- include('../partials/confirm-modal') %>
<script src="/js/app.js"></script>
</body>
</html>
