<!DOCTYPE html>
<html lang="fr" class="h-full bg-gray-100">
<head>
  <meta charset="UTF-8"><link rel="icon" href="/favicon.svg" type="image/svg+xml"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Paramètres — Voilà Voilà Tools</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/app.css">
  <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.14.1/dist/cdn.min.js"></script>
  <script src="https://unpkg.com/htmx.org@2.0.0/dist/htmx.min.js"></script>
</head>
<body class="h-full" x-data="{ sidebarOpen: false }">
<div id="htmx-progress"></div>
<div class="flex h-full">
  <div x-cloak x-show="sidebarOpen" @click="sidebarOpen=false" class="fixed inset-0 bg-gray-900/50 z-20 lg:hidden"></div>
  <aside class="fixed inset-y-0 left-0 z-30 w-64 bg-white border-r border-gray-200 flex flex-col transition-transform duration-300 lg:translate-x-0 lg:static lg:flex" :class="sidebarOpen ? 'translate-x-0' : '-translate-x-full'">
    <%- include('../partials/sidebar') %>
  </aside>
  <div class="flex-1 flex flex-col min-w-0 overflow-hidden">
    <%- include('../partials/header') %>
    <main class="flex-1 overflow-y-auto p-6">
      <%- include('../partials/flash') %>

      <!-- En-tête -->
      <div class="mb-6">
        <h1 class="text-2xl font-bold text-gray-900">Paramètres</h1>
        <p class="text-sm text-gray-500 mt-0.5">Gérez les informations de votre organisation</p>
      </div>

      <% if (errors && errors.length > 0) { %>
      <div class="mb-6 p-4 bg-red-50 border border-red-200 rounded-lg">
        <ul class="list-disc list-inside space-y-1">
          <% errors.forEach(e => { %><li class="text-sm text-red-700"><%= e %></li><% }) %>
        </ul>
      </div>
      <% } %>

      <div class="max-w-2xl space-y-5">
        <form method="POST" action="/o/<%= org.slug %>/settings?_method=PUT" enctype="multipart/form-data">
          <input type="hidden" name="_method" value="PUT">

          <!-- Informations générales -->
          <div class="card">
            <div class="card-header">
              <h2 class="text-sm font-semibold text-gray-900">Informations générales</h2>
            </div>
            <div class="card-body space-y-4">
              <div>
                <label class="form-label" for="org-name">Nom de l'organisation</label>
                <input type="text" id="org-name" name="name" class="form-input"
                  value="<%= org.name %>"
                  placeholder="Mon Organisation" required>
              </div>
              <div>
                <label class="form-label">Identifiant (slug)</label>
                <input type="text" class="form-input bg-gray-50 text-gray-400 cursor-not-allowed"
                  value="<%= org.slug %>" disabled>
                <p class="form-hint">L'identifiant ne peut pas être modifié.</p>
              </div>
            </div>
          </div>

          <!-- Logo -->
          <div class="card">
            <div class="card-header">
              <h2 class="text-sm font-semibold text-gray-900">Logo</h2>
            </div>
            <div class="card-body space-y-4">
              <% if (org.logo) { %>
              <div class="flex items-center gap-4 p-4 bg-gray-50 rounded-xl">
                <img src="<%= org.logo %>" alt="Logo actuel" class="h-14 object-contain rounded-lg">
                <div>
                  <p class="text-sm font-medium text-gray-700">Logo actuel</p>
                  <label class="flex items-center gap-1.5 mt-2 cursor-pointer">
                    <input type="checkbox" name="removeLogo" value="true" class="w-3.5 h-3.5">
                    <span class="text-xs text-red-600 font-medium">Supprimer le logo</span>
                  </label>
                </div>
              </div>
              <% } %>
              <div>
                <label class="form-label"><%= org.logo ? 'Nouveau logo' : 'Logo' %> <span class="text-gray-400 font-normal">(PNG, JPG, SVG)</span></label>
                <input type="file" name="logo" accept="image/*"
                  class="form-input text-sm file:mr-3 file:py-1.5 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-medium file:bg-brand-50 file:text-brand-700 hover:file:bg-brand-100 cursor-pointer">
              </div>
            </div>
          </div>

          <!-- Actions -->
          <div class="flex justify-end">
            <button type="submit" class="btn-primary">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              Enregistrer les modifications
            </button>
          </div>
        </form>

        <!-- Zone de danger -->
        <div class="card border border-red-100">
          <div class="card-header border-b border-red-50">
            <h2 class="text-sm font-semibold text-red-600">Zone de danger</h2>
          </div>
          <div class="card-body">
            <div class="flex items-start justify-between gap-4">
              <div>
                <p class="text-sm font-medium text-gray-900">Supprimer l'organisation</p>
                <p class="text-xs text-gray-500 mt-1">Cette action est irréversible. Toutes les données associées seront supprimées définitivement.</p>
              </div>
              <button
                class="btn-danger btn-sm flex-shrink-0"
                hx-delete="/o/<%= org.slug %>"
                hx-confirm="Supprimer définitivement l'organisation « <%= org.name %> » et toutes ses données ?"
                hx-push-url="/"
              >
                Supprimer
              </button>
            </div>
          </div>
        </div>
      </div>

    </main>
  </div>
</div>
<%- include('../partials/confirm-modal') %>
<script src="/js/app.js"></script>
</body>
</html>
