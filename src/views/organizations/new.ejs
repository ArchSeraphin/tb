<!DOCTYPE html>
<html lang="fr" class="h-full">
<head>
  <meta charset="UTF-8">
  <link rel="icon" href="/voilavoila-favicon.webp" type="image/webp">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Nouvelle organisation — Voilà Voilà Tools</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@600;700;800&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/app.css">
</head>
<body class="h-full flex">

  <!-- Panneau gauche -->
  <div class="hidden lg:flex lg:w-[55%] vv-sidebar flex-col justify-between p-12">
    <div>
      <img src="/img/voilavoila-logo-blanc.webp" alt="Voilà Voilà Tools" class="h-8 object-contain">
    </div>
    <div>
      <h1 class="text-white font-display text-4xl font-bold leading-tight mb-4">
        Votre espace<br>de travail collaboratif.
      </h1>
      <p class="text-white/60 text-base leading-relaxed max-w-sm">
        Créez une organisation, invitez vos collaborateurs et gérez ensemble vos QR codes, signatures et vCards.
      </p>
    </div>
    <div class="flex items-center gap-6">
      <div class="text-center">
        <p class="text-white text-2xl font-bold">QR</p>
        <p class="text-white/50 text-xs mt-0.5">Codes</p>
      </div>
      <div class="w-px h-8 bg-white/20"></div>
      <div class="text-center">
        <p class="text-white text-2xl font-bold">✉</p>
        <p class="text-white/50 text-xs mt-0.5">Signatures</p>
      </div>
      <div class="w-px h-8 bg-white/20"></div>
      <div class="text-center">
        <p class="text-white text-2xl font-bold">☑</p>
        <p class="text-white/50 text-xs mt-0.5">VCards</p>
      </div>
    </div>
  </div>

  <!-- Panneau droit : formulaire -->
  <div class="flex-1 flex flex-col items-center justify-center px-6 py-12 bg-white overflow-y-auto">

    <div class="lg:hidden mb-8 text-center">
      <img src="/img/Logo_Voila Voila_RVB.png" alt="Voilà Voilà Tools" class="h-10 object-contain mx-auto">
    </div>

    <div class="w-full max-w-sm">
      <div class="mb-8">
        <h2 class="text-2xl font-bold text-gray-900">Créer une organisation</h2>
        <p class="text-sm text-gray-500 mt-1">Donnez un nom à votre espace de travail</p>
      </div>

      <%- include('../partials/flash') %>

      <% if (errors && errors.length > 0) { %>
      <div class="mb-4 p-3 bg-red-50 border border-red-200 rounded-lg">
        <% errors.forEach(e => { %><p class="text-sm text-red-700"><%= e.msg %></p><% }) %>
      </div>
      <% } %>

      <form method="POST" action="/o" class="space-y-4">
        <div>
          <label class="form-label" for="name">Nom de l'organisation</label>
          <input type="text" id="name" name="name" required class="form-input"
                 placeholder="Ex : Acme Studio, Mon Agence…"
                 value="<%= old?.name || '' %>"
                 autofocus>
          <p class="form-hint mt-1">Ce nom sera visible par tous les membres.</p>
        </div>

        <button type="submit" class="btn-primary w-full justify-center py-3 mt-2">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
          </svg>
          Créer l'organisation
        </button>
      </form>

      <% if (typeof userOrgs !== 'undefined' && userOrgs && userOrgs.length > 0) { %>
      <p class="text-center text-sm text-gray-500 mt-6">
        <a href="/dashboard" class="text-brand-600 hover:text-brand-700 font-semibold">← Retour au tableau de bord</a>
      </p>
      <% } %>

      <p class="text-center text-sm text-gray-400 mt-4">
        Connecté en tant que <span class="font-medium text-gray-600"><%= user?.name %></span> ·
        <a href="/auth/logout" class="hover:text-gray-600">Déconnexion</a>
      </p>
    </div>
  </div>

</body>
</html>
