<!DOCTYPE html>
<html lang="fr" class="h-full bg-gray-50">
<head>
  <meta charset="UTF-8"><link rel="icon" href="/voilavoila-favicon.webp" type="image/webp"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Membres — Voilà Voilà Tools</title>
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@600;700;800&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/app.css">
  <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.14.1/dist/cdn.min.js"></script>
  <script src="https://unpkg.com/htmx.org@2.0.0/dist/htmx.min.js"></script>
</head>
<body class="h-full" x-data="{ sidebarOpen: false }">
<div id="htmx-progress"></div>
<div class="flex h-full">
  <div x-cloak x-show="sidebarOpen" @click="sidebarOpen=false" class="fixed inset-0 bg-gray-900/50 z-20 lg:hidden"></div>
  <aside class="fixed inset-y-0 left-0 z-30 w-64 vv-sidebar flex flex-col transition-transform duration-300 lg:translate-x-0 lg:static lg:flex" :class="sidebarOpen ? 'translate-x-0' : '-translate-x-full'">
    <%- include('../partials/sidebar') %>
  </aside>
  <div class="flex-1 flex flex-col min-w-0 overflow-hidden">
    <%- include('../partials/header') %>
    <main class="flex-1 overflow-y-auto p-6">
      <%- include('../partials/flash') %>

      <!-- En-tête -->
      <div class="mb-6">
        <h1 class="text-2xl font-bold text-gray-900">Membres</h1>
        <p class="text-sm text-gray-500 mt-0.5"><%= members.length %> membre<%= members.length > 1 ? 's' : '' %></p>
      </div>

      <div class="max-w-3xl space-y-5">

        <!-- Formulaire d'invitation (admin/owner seulement) -->
        <% if (membership?.role === 'owner' || membership?.role === 'admin') { %>
        <div class="card">
          <div class="card-header">
            <h2 class="text-sm font-semibold text-gray-900">Inviter un membre</h2>
          </div>
          <div class="card-body">
            <% if (errors && errors.length > 0) { %>
            <div class="mb-4 p-3 bg-red-50 border border-red-200 rounded-lg">
              <ul class="list-disc list-inside space-y-1">
                <% errors.forEach(e => { %><li class="text-sm text-red-700"><%= e %></li><% }) %>
              </ul>
            </div>
            <% } %>
            <form method="POST" action="/o/<%= currentOrg.slug %>/members/invite" class="flex gap-3">
              <div class="flex-1">
                <label class="form-label sr-only" for="invite-email">Adresse email</label>
                <input type="email" id="invite-email" name="email" class="form-input"
                  placeholder="prénom@exemple.fr" required
                  value="<%= old?.email || '' %>">
              </div>
              <button type="submit" class="btn-primary flex-shrink-0">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/></svg>
                Inviter
              </button>
            </form>
            <p class="form-hint mt-2">L'utilisateur doit déjà avoir un compte. Il aura immédiatement accès à l'organisation.</p>
          </div>
        </div>
        <% } %>

        <!-- Liste des membres -->
        <div class="card overflow-hidden">
          <div class="card-header">
            <h2 class="text-sm font-semibold text-gray-900">Membres de l'organisation</h2>
          </div>
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-gray-100 bg-gray-50">
                <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Membre</th>
                <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider hidden md:table-cell">Email</th>
                <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Rôle</th>
                <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider hidden lg:table-cell">Membre depuis</th>
                <th class="px-4 py-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider">Actions</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-50" id="members-table-body">
              <% members.forEach(member => { %>
              <tr class="hover:bg-gray-50 transition-colors" id="member-row-<%= member.id %>">
                <td class="px-4 py-3">
                  <div class="flex items-center gap-3">
                    <div class="w-8 h-8 rounded-full flex-shrink-0 flex items-center justify-center text-brand-600 text-sm font-bold bg-brand-100">
                      <%= (member.user?.name || member.user?.email || '?')[0].toUpperCase() %>
                    </div>
                    <div class="min-w-0">
                      <p class="font-medium text-gray-900 truncate">
                        <%= member.user?.name || 'Utilisateur' %>
                        <% if (member.user?.id === user?.id) { %><span class="ml-1 text-xs text-gray-400">(vous)</span><% } %>
                      </p>
                      <p class="text-xs text-gray-400 truncate md:hidden"><%= member.user?.email || '' %></p>
                    </div>
                  </div>
                </td>
                <td class="px-4 py-3 hidden md:table-cell">
                  <span class="text-gray-500"><%= member.user?.email || '—' %></span>
                </td>
                <td class="px-4 py-3">
                  <% if (member.role === 'owner') { %>
                  <span class="badge badge-blue">Propriétaire</span>
                  <% } else if (membership?.role === 'owner' || membership?.role === 'admin') { %>
                    <% if (member.user?.id !== user?.id) { %>
                    <form method="POST" action="/o/<%= currentOrg.slug %>/members/<%= member.id %>/role" class="inline">
                      <input type="hidden" name="_method" value="PUT">
                      <select name="role" onchange="this.form.submit()"
                        class="text-xs border border-gray-200 rounded-md px-2 py-1 bg-white text-gray-700 cursor-pointer hover:border-brand-400 focus:outline-none focus:ring-1 focus:ring-brand-500">
                        <option value="member" <%= member.role === 'member' ? 'selected' : '' %>>Membre</option>
                        <option value="admin" <%= member.role === 'admin' ? 'selected' : '' %>>Admin</option>
                      </select>
                    </form>
                    <% } else { %>
                    <span class="badge badge-<%= member.role === 'admin' ? 'green' : 'gray' %>"><%= member.role === 'admin' ? 'Admin' : 'Membre' %></span>
                    <% } %>
                  <% } else { %>
                  <span class="badge badge-<%= member.role === 'admin' ? 'green' : 'gray' %>"><%= member.role === 'admin' ? 'Admin' : 'Membre' %></span>
                  <% } %>
                </td>
                <td class="px-4 py-3 hidden lg:table-cell">
                  <span class="text-gray-400 text-xs">
                    <%= member.acceptedAt ? new Date(member.acceptedAt).toLocaleDateString('fr-FR') : '—' %>
                  </span>
                </td>
                <td class="px-4 py-3 text-right">
                  <% if (member.role === 'owner') { %>
                  <span class="text-xs text-gray-300">—</span>
                  <% } else if (member.user?.id === user?.id) { %>
                  <form method="POST" action="/o/<%= currentOrg.slug %>/leave" class="inline"
                    onsubmit="return confirm('Quitter l\'organisation ? Vous perdrez l\'accès à toutes ses ressources.')">
                    <button type="submit" class="text-xs text-red-400 hover:text-red-600 transition-colors px-2 py-1 rounded hover:bg-red-50">
                      Quitter
                    </button>
                  </form>
                  <% } else if (membership?.role === 'owner' || membership?.role === 'admin') { %>
                  <form method="POST" action="/o/<%= currentOrg.slug %>/members/<%= member.id %>/remove" class="inline">
                    <input type="hidden" name="_method" value="DELETE">
                    <button type="submit"
                      class="text-gray-400 hover:text-red-500 transition-colors p-1 rounded"
                      title="Retirer ce membre"
                      onclick="return confirm('Retirer <%= (member.user?.name || member.user?.email || 'ce membre').replace(/'/g, "\\'") %> de l\'organisation ?')">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7a4 4 0 11-8 0 4 4 0 018 0zM9 14a6 6 0 00-6 6v1h12v-1a6 6 0 00-6-6zm7-7l5 5m0-5l-5 5"/>
                      </svg>
                    </button>
                  </form>
                  <% } else { %>
                  <span class="text-xs text-gray-300">—</span>
                  <% } %>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>

      </div>

    </main>
  </div>
</div>
<%- include('../partials/confirm-modal') %>
<script src="/js/app.js"></script>
</body>
</html>
