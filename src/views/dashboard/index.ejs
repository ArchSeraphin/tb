<!DOCTYPE html>
<html lang="fr" class="h-full bg-gray-100">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Tableau de bord — Voilà Voilà Tools</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/app.css">
  <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
  <script src="https://unpkg.com/htmx.org@2.0.0/dist/htmx.min.js"></script>
</head>
<body class="h-full" x-data="{ sidebarOpen: false }">
<div class="flex h-full">
  <div x-show="sidebarOpen" @click="sidebarOpen=false" class="fixed inset-0 bg-gray-900/50 z-20 lg:hidden"></div>
  <aside class="fixed inset-y-0 left-0 z-30 w-64 bg-white border-r border-gray-200 flex flex-col transition-transform duration-300 lg:translate-x-0 lg:static lg:flex" :class="sidebarOpen ? 'translate-x-0' : '-translate-x-full'">
    <%- include('../partials/sidebar') %>
  </aside>
  <div class="flex-1 flex flex-col min-w-0 overflow-hidden">
    <%- include('../partials/header') %>
    <main class="flex-1 overflow-y-auto p-6">
      <%- include('../partials/flash') %>

      <div class="mb-6">
        <h1 class="text-2xl font-bold text-gray-900">Bonjour, <%= user?.name?.split(' ')[0] %> 👋</h1>
        <p class="text-gray-500 mt-1">Voici un aperçu de votre activité</p>
      </div>

      <% if (stats && org) { %>
      <!-- Stats cards -->
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
        <div class="card p-5">
          <p class="text-xs font-medium text-gray-500 uppercase tracking-wider">QR Codes</p>
          <p class="text-3xl font-bold text-gray-900 mt-1"><%= stats.qrCount %></p>
          <a href="/o/<%= org.slug %>/qr" class="text-xs text-brand-600 hover:text-brand-700 mt-2 inline-block">Gérer →</a>
        </div>
        <div class="card p-5">
          <p class="text-xs font-medium text-gray-500 uppercase tracking-wider">Signatures</p>
          <p class="text-3xl font-bold text-gray-900 mt-1"><%= stats.sigCount %></p>
          <a href="/o/<%= org.slug %>/signatures" class="text-xs text-brand-600 hover:text-brand-700 mt-2 inline-block">Gérer →</a>
        </div>
        <div class="card p-5">
          <p class="text-xs font-medium text-gray-500 uppercase tracking-wider">VCards</p>
          <p class="text-3xl font-bold text-gray-900 mt-1"><%= stats.vcardCount %></p>
          <a href="/o/<%= org.slug %>/vcards" class="text-xs text-brand-600 hover:text-brand-700 mt-2 inline-block">Gérer →</a>
        </div>
        <div class="card p-5">
          <p class="text-xs font-medium text-gray-500 uppercase tracking-wider">Clics QR</p>
          <p class="text-3xl font-bold text-gray-900 mt-1"><%= stats.totalClicks %></p>
          <span class="text-xs text-gray-400 mt-2 inline-block">Total</span>
        </div>
      </div>

      <!-- Accès rapide -->
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <a href="/o/<%= org.slug %>/qr/create" class="card p-5 hover:shadow-md transition-shadow group">
          <div class="w-10 h-10 bg-brand-50 rounded-lg flex items-center justify-center mb-3 group-hover:bg-brand-100 transition-colors">
            <svg class="w-5 h-5 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
            </svg>
          </div>
          <h3 class="text-sm font-semibold text-gray-900">Nouveau QR Code</h3>
          <p class="text-xs text-gray-500 mt-0.5">Créer un lien court avec QR</p>
        </a>
        <a href="/o/<%= org.slug %>/signatures/create" class="card p-5 hover:shadow-md transition-shadow group">
          <div class="w-10 h-10 bg-green-50 rounded-lg flex items-center justify-center mb-3 group-hover:bg-green-100 transition-colors">
            <svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
            </svg>
          </div>
          <h3 class="text-sm font-semibold text-gray-900">Nouvelle Signature</h3>
          <p class="text-xs text-gray-500 mt-0.5">Générateur de signature email</p>
        </a>
        <a href="/o/<%= org.slug %>/vcards/create" class="card p-5 hover:shadow-md transition-shadow group">
          <div class="w-10 h-10 bg-purple-50 rounded-lg flex items-center justify-center mb-3 group-hover:bg-purple-100 transition-colors">
            <svg class="w-5 h-5 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
            </svg>
          </div>
          <h3 class="text-sm font-semibold text-gray-900">Nouvelle VCard</h3>
          <p class="text-xs text-gray-500 mt-0.5">Page de contact mobile</p>
        </a>
      </div>

      <% } else { %>
      <!-- Empty state : aucune organisation -->
      <div class="card p-12 text-center max-w-md mx-auto">
        <div class="w-16 h-16 bg-brand-50 rounded-full flex items-center justify-center mx-auto mb-4">
          <svg class="w-8 h-8 text-brand-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-gray-900 mb-2">Aucune organisation</h3>
        <p class="text-sm text-gray-500">Votre compte n'a pas encore d'organisation associée.</p>
      </div>
      <% } %>

    </main>
  </div>
</div>
<script src="/js/app.js"></script>
</body>
</html>
