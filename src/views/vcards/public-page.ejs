<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
  <title><%= vcard.identity?.firstName ? `${vcard.identity.firstName} ${vcard.identity.lastName || ''}` : vcard.name %></title>
  <%
    const fontMap = {
      inter: 'Inter',
      poppins: 'Poppins',
      montserrat: 'Montserrat',
      nunito: 'Nunito'
    };
    const fontFamily = fontMap[vcard.design?.fontStyle] || 'Inter';
    const fontWeights = '400;500;600;700';
  %>
  <link href="https://fonts.googleapis.com/css2?family=<%= fontFamily %>:wght@<%= fontWeights %>&display=swap" rel="stylesheet">
  <style>
    :root {
      --color-bg: <%= vcard.design?.colorBg || '#f8fafc' %>;
      --color-card: <%= vcard.design?.colorCard || '#ffffff' %>;
      --color-text: <%= vcard.design?.colorText || '#1f2937' %>;
      --color-btn: <%= vcard.design?.colorBtn || '#5b6af5' %>;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    html, body {
      min-height: 100%;
      background-color: var(--color-bg);
      font-family: '<%= fontFamily %>', sans-serif;
      color: var(--color-text);
      -webkit-font-smoothing: antialiased;
    }
    .page-wrapper {
      min-height: 100vh;
      display: flex;
      align-items: flex-start;
      justify-content: center;
      padding: 24px 16px 48px;
    }
    .page-inner {
      width: 100%;
      max-width: 420px;
    }
    .logo-wrapper {
      display: flex;
      justify-content: center;
      margin-bottom: 20px;
    }
    .logo-wrapper img {
      max-height: 56px;
      max-width: 180px;
      object-fit: contain;
    }
    .card {
      background-color: var(--color-card);
      border-radius: 20px;
      overflow: hidden;
      box-shadow: 0 4px 24px rgba(0,0,0,0.08);
    }
    .photo-wrapper {
      display: flex;
      justify-content: center;
      margin-top: -36px;
      margin-bottom: 12px;
    }
    .photo-wrapper img {
      width: 80px;
      height: 80px;
      border-radius: 50%;
      object-fit: cover;
      border: 4px solid var(--color-card);
      box-shadow: 0 2px 12px rgba(0,0,0,0.12);
    }
    .photo-placeholder {
      width: 80px;
      height: 80px;
      border-radius: 50%;
      background: #e5e7eb;
      border: 4px solid var(--color-card);
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .card-top-bg {
      height: 80px;
      background-color: var(--color-btn);
      background-size: cover;
      background-position: center;
    }
    .card-body {
      padding: 0 20px 24px;
    }
    .name-block {
      text-align: center;
      margin-bottom: 16px;
    }
    .name-block h1 {
      font-size: 1.25rem;
      font-weight: 700;
      color: var(--color-text);
      line-height: 1.3;
    }
    .btn-main {
      display: block;
      width: 100%;
      padding: 14px;
      background-color: var(--color-btn);
      color: #fff;
      text-align: center;
      text-decoration: none;
      font-weight: 600;
      font-size: 0.9375rem;
      border-radius: 12px;
      margin-bottom: 16px;
      border: none;
      cursor: pointer;
      transition: opacity 0.15s;
    }
    .btn-main:hover { opacity: 0.9; }
    .divider {
      height: 1px;
      background: #f0f0f0;
      margin: 16px 0;
    }
    .contact-list {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 10px;
      margin-bottom: 16px;
    }
    .contact-list li a,
    .contact-list li span {
      display: flex;
      align-items: center;
      gap: 12px;
      color: var(--color-text);
      text-decoration: none;
      font-size: 0.875rem;
    }
    .contact-icon {
      width: 36px;
      height: 36px;
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }
    .contact-icon svg {
      width: 18px;
      height: 18px;
    }
    .social-grid {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      justify-content: center;
      margin-bottom: 16px;
    }
    .social-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 44px;
      height: 44px;
      border-radius: 12px;
      background-color: var(--color-btn);
      color: #fff;
      text-decoration: none;
      transition: opacity 0.15s;
    }
    .social-btn:hover { opacity: 0.85; }
    .social-btn svg { width: 20px; height: 20px; }
    .btn-outline {
      display: block;
      width: 100%;
      padding: 12px;
      border: 2px solid var(--color-btn);
      color: var(--color-btn);
      background: transparent;
      text-align: center;
      text-decoration: none;
      font-weight: 600;
      font-size: 0.875rem;
      border-radius: 12px;
      margin-bottom: 8px;
      cursor: pointer;
      transition: background 0.15s, color 0.15s;
    }
    .btn-outline:hover {
      background: var(--color-btn);
      color: #fff;
    }
    .btn-vcf {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      width: 100%;
      padding: 12px;
      border: 2px solid var(--color-btn);
      color: var(--color-btn);
      background: transparent;
      text-align: center;
      text-decoration: none;
      font-weight: 600;
      font-size: 0.875rem;
      border-radius: 12px;
      margin-top: 8px;
      transition: background 0.15s, color 0.15s;
    }
    .btn-vcf:hover {
      background: var(--color-btn);
      color: #fff;
    }
    .powered {
      text-align: center;
      margin-top: 24px;
      font-size: 0.75rem;
      color: #9ca3af;
    }
    .powered a { color: #9ca3af; text-decoration: none; }
  </style>
</head>
<body>
  <div class="page-wrapper">
    <div class="page-inner">

      <!-- Logo au-dessus de la carte -->
      <% if (vcard.mediaPaths?.logo) { %>
      <div class="logo-wrapper">
        <img src="<%= vcard.mediaPaths.logo %>" alt="Logo">
      </div>
      <% } %>

      <div class="card">
        <!-- Fond coloré en haut (pour la photo) -->
        <div class="card-top-bg"<% if (vcard.mediaPaths?.background) { %> style="background-image: url('<%= vcard.mediaPaths.background %>')"<% } %>></div>

        <div class="card-body">
          <!-- Photo de profil -->
          <% if (vcard.identity?.showPhoto) { %>
          <div class="photo-wrapper">
            <% if (vcard.mediaPaths?.photo) { %>
            <img src="<%= vcard.mediaPaths.photo %>" alt="<%= vcard.identity?.firstName || vcard.name %>">
            <% } else { %>
            <div class="photo-placeholder">
              <svg fill="none" stroke="#9ca3af" viewBox="0 0 24 24" width="32" height="32"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
            </div>
            <% } %>
          </div>
          <% } else { %>
          <div style="height: 16px;"></div>
          <% } %>

          <!-- Nom -->
          <% if (vcard.identity?.showName) { %>
          <div class="name-block">
            <h1><%= vcard.identity?.firstName ? `${vcard.identity.firstName}${vcard.identity.lastName ? ' ' + vcard.identity.lastName : ''}` : vcard.name %></h1>
          </div>
          <% } %>

          <!-- Bouton principal -->
          <% if (vcard.contact?.mainButtonText && vcard.contact?.mainButtonUrl) { %>
          <a href="<%= vcard.contact.mainButtonUrl %>" class="btn-main"><%= vcard.contact.mainButtonText %></a>
          <% } else if (vcard.contact?.mainButtonText && vcard.contact?.phone) { %>
          <a href="tel:<%= vcard.contact.phone %>" class="btn-main"><%= vcard.contact.mainButtonText || 'Me contacter' %></a>
          <% } %>

          <div class="divider"></div>

          <!-- Informations de contact -->
          <% const hasContact = vcard.contact?.phone || vcard.contact?.email || vcard.contact?.address; %>
          <% if (hasContact) { %>
          <ul class="contact-list">
            <% if (vcard.contact?.phone) { %>
            <li>
              <a href="tel:<%= vcard.contact.phone %>">
                <span class="contact-icon" style="background-color: color-mix(in srgb, var(--color-btn) 15%, transparent);">
                  <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color: var(--color-btn)">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                  </svg>
                </span>
                <span><%= vcard.contact.phone %></span>
              </a>
            </li>
            <% } %>
            <% if (vcard.contact?.email) { %>
            <li>
              <a href="mailto:<%= vcard.contact.email %>">
                <span class="contact-icon" style="background-color: color-mix(in srgb, var(--color-btn) 15%, transparent);">
                  <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color: var(--color-btn)">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                  </svg>
                </span>
                <span><%= vcard.contact.email %></span>
              </a>
            </li>
            <% } %>
            <% if (vcard.contact?.address) { %>
            <li>
              <% if (vcard.contact?.mapsUrl) { %>
              <a href="<%= vcard.contact.mapsUrl %>" target="_blank" rel="noopener">
              <% } else { %>
              <span>
              <% } %>
                <span class="contact-icon" style="background-color: color-mix(in srgb, var(--color-btn) 15%, transparent);">
                  <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color: var(--color-btn)">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                  </svg>
                </span>
                <span><%= vcard.contact.address %></span>
              <% if (vcard.contact?.mapsUrl) { %></a><% } else { %></span><% } %>
            </li>
            <% } %>
          </ul>
          <% } %>

          <!-- Réseaux sociaux -->
          <% if (vcard.socialLinks && vcard.socialLinks.length > 0) { %>
          <div class="divider"></div>
          <div class="social-grid">
            <% vcard.socialLinks.forEach(social => { %>
            <% if (social.url) { %>
            <a href="<%= social.url %>" target="_blank" rel="noopener" class="social-btn" title="<%= social.type %>">
              <%- socialIcon(social.type) %>
            </a>
            <% } %>
            <% }) %>
          </div>
          <% } %>

          <!-- Boutons supplémentaires -->
          <% if (vcard.extraButtons && vcard.extraButtons.length > 0) { %>
          <div class="divider"></div>
          <div>
            <% vcard.extraButtons.forEach(btn => { %>
            <% if (btn.text && btn.url) { %>
            <a href="<%= btn.url %>" class="btn-outline"><%= btn.text %></a>
            <% } %>
            <% }) %>
          </div>
          <% } %>

          <!-- Bouton télécharger vCard -->
          <% if (vcard.showVcard) { %>
          <div class="divider"></div>
          <a href="/v/<%= org.slug %>/<%= vcard.slug %>/contact.vcf" class="btn-vcf">
            <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
            </svg>
            Télécharger le contact
          </a>
          <% } %>
        </div>
      </div>

      <p class="powered">Propulsé par <a href="/" target="_blank">Voilà Voilà Tools</a></p>

    </div>
  </div>
</body>
</html>
