<!DOCTYPE html>
<html lang="fr" class="h-full bg-gray-100">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= vcard ? 'Modifier' : 'Nouvelle' %> VCard — Voilà Voilà Tools</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/app.css">
  <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
  <script src="https://unpkg.com/htmx.org@2.0.0/dist/htmx.min.js"></script>
</head>
<body class="h-full" x-data="{ sidebarOpen: false }">
<div class="flex h-full">
  <div x-show="sidebarOpen" @click="sidebarOpen=false" class="fixed inset-0 bg-gray-900/50 z-20 lg:hidden"></div>
  <aside class="fixed inset-y-0 left-0 z-30 w-64 bg-white border-r border-gray-200 flex flex-col transition-transform duration-300 lg:translate-x-0 lg:static lg:flex" :class="sidebarOpen ? 'translate-x-0' : '-translate-x-full'">
    <%- include('../partials/sidebar') %>
  </aside>
  <div class="flex-1 flex flex-col min-w-0 overflow-hidden">
    <%- include('../partials/header') %>
    <main class="flex-1 overflow-y-auto p-6">
      <%- include('../partials/flash') %>

      <!-- En-tête -->
      <div class="flex items-center gap-3 mb-6">
        <a href="/o/<%= currentOrg.slug %>/vcards" class="text-gray-400 hover:text-gray-600 transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        </a>
        <div>
          <h1 class="text-2xl font-bold text-gray-900"><%= vcard ? 'Modifier la VCard' : 'Nouvelle VCard' %></h1>
          <% if (vcard) { %><p class="text-sm text-gray-500 mt-0.5"><%= vcard.name %></p><% } %>
        </div>
      </div>

      <% if (errors && errors.length > 0) { %>
      <div class="mb-6 p-4 bg-red-50 border border-red-200 rounded-lg">
        <ul class="list-disc list-inside space-y-1">
          <% errors.forEach(e => { %><li class="text-sm text-red-700"><%= e %></li><% }) %>
        </ul>
      </div>
      <% } %>

      <!-- Layout deux colonnes -->
      <div x-data="vcardForm()" class="flex gap-6 items-start">
        <!-- Colonne gauche : formulaire -->
        <div class="flex-1 min-w-0 space-y-5">
          <form
            method="POST"
            action="<%= vcard ? `/o/${currentOrg.slug}/vcards/${vcard.id}?_method=PUT` : `/o/${currentOrg.slug}/vcards` %>"
            enctype="multipart/form-data"
          >
            <% if (vcard) { %>
            <input type="hidden" name="_method" value="PUT">
            <% } %>

            <!-- Section Informations -->
            <div class="card">
              <div class="card-header">
                <h2 class="text-sm font-semibold text-gray-900">Informations</h2>
              </div>
              <div class="card-body space-y-4">
                <div>
                  <label class="form-label">Nom de la VCard</label>
                  <input type="text" name="name" class="form-input"
                    value="<%= old?.name || vcard?.name || '' %>"
                    placeholder="Ex: Ma carte pro" required
                    x-model="vcName">
                </div>
                <div class="grid grid-cols-2 gap-4">
                  <div>
                    <label class="form-label">Prénom</label>
                    <input type="text" name="identity[firstName]" class="form-input"
                      value="<%= old?.identity?.firstName || vcard?.identity?.firstName || '' %>"
                      placeholder="Jean"
                      x-model="firstName">
                  </div>
                  <div>
                    <label class="form-label">Nom de famille</label>
                    <input type="text" name="identity[lastName]" class="form-input"
                      value="<%= old?.identity?.lastName || vcard?.identity?.lastName || '' %>"
                      placeholder="Dupont"
                      x-model="lastName">
                  </div>
                </div>
              </div>
            </div>

            <!-- Section Options d'affichage -->
            <div class="card">
              <div class="card-header">
                <h2 class="text-sm font-semibold text-gray-900">Options d'affichage</h2>
              </div>
              <div class="card-body space-y-3">
                <label class="flex items-center gap-3 cursor-pointer">
                  <input type="checkbox" name="identity[showName]" value="true"
                    <%= (old?.identity?.showName !== undefined ? old?.identity?.showName : vcard?.identity?.showName !== false) ? 'checked' : '' %>
                    x-model="showName"
                    class="w-4 h-4 rounded border-gray-300 text-brand-600 accent-brand-600">
                  <span class="text-sm text-gray-700">Afficher le nom</span>
                </label>
                <label class="flex items-center gap-3 cursor-pointer">
                  <input type="checkbox" name="identity[showPhoto]" value="true"
                    <%= (old?.identity?.showPhoto !== undefined ? old?.identity?.showPhoto : vcard?.identity?.showPhoto !== false) ? 'checked' : '' %>
                    x-model="showPhoto"
                    class="w-4 h-4 rounded border-gray-300 text-brand-600 accent-brand-600">
                  <span class="text-sm text-gray-700">Afficher la photo</span>
                </label>
                <label class="flex items-center gap-3 cursor-pointer">
                  <input type="checkbox" name="showVcard" value="true"
                    <%= (old?.showVcard !== undefined ? old?.showVcard : vcard?.showVcard !== false) ? 'checked' : '' %>
                    x-model="showVcard"
                    class="w-4 h-4 rounded border-gray-300 text-brand-600 accent-brand-600">
                  <span class="text-sm text-gray-700">Afficher le bouton télécharger VCard</span>
                </label>
                <label class="flex items-center gap-3 cursor-pointer">
                  <input type="checkbox" name="isPublished" value="true"
                    <%= (old?.isPublished !== undefined ? old?.isPublished : vcard?.isPublished) ? 'checked' : '' %>
                    x-model="isPublished"
                    class="w-4 h-4 rounded border-gray-300 text-brand-600 accent-brand-600">
                  <span class="text-sm text-gray-700">Publier la page</span>
                </label>
              </div>
            </div>

            <!-- Section Contact -->
            <div class="card">
              <div class="card-header">
                <h2 class="text-sm font-semibold text-gray-900">Contact</h2>
              </div>
              <div class="card-body space-y-4">
                <div class="grid grid-cols-2 gap-4">
                  <div>
                    <label class="form-label">Téléphone</label>
                    <input type="tel" name="contact[phone]" class="form-input"
                      value="<%= old?.contact?.phone || vcard?.contact?.phone || '' %>"
                      placeholder="+33 6 00 00 00 00"
                      x-model="phone">
                  </div>
                  <div>
                    <label class="form-label">Email</label>
                    <input type="email" name="contact[email]" class="form-input"
                      value="<%= old?.contact?.email || vcard?.contact?.email || '' %>"
                      placeholder="jean@exemple.fr"
                      x-model="contactEmail">
                  </div>
                </div>
                <div>
                  <label class="form-label">Adresse</label>
                  <input type="text" name="contact[address]" class="form-input"
                    value="<%= old?.contact?.address || vcard?.contact?.address || '' %>"
                    placeholder="12 rue de la Paix, 75001 Paris"
                    x-model="address">
                </div>
                <div>
                  <label class="form-label">Lien Google Maps</label>
                  <input type="url" name="contact[mapsUrl]" class="form-input"
                    value="<%= old?.contact?.mapsUrl || vcard?.contact?.mapsUrl || '' %>"
                    placeholder="https://maps.google.com/...">
                </div>
                <div class="grid grid-cols-2 gap-4">
                  <div>
                    <label class="form-label">Texte bouton principal</label>
                    <input type="text" name="contact[mainButtonText]" class="form-input"
                      value="<%= old?.contact?.mainButtonText || vcard?.contact?.mainButtonText || 'Me contacter' %>"
                      x-model="mainButtonText">
                  </div>
                  <div>
                    <label class="form-label">URL bouton principal</label>
                    <input type="url" name="contact[mainButtonUrl]" class="form-input"
                      value="<%= old?.contact?.mainButtonUrl || vcard?.contact?.mainButtonUrl || '' %>"
                      placeholder="https://...">
                  </div>
                </div>
              </div>
            </div>

            <!-- Section Design -->
            <div class="card">
              <div class="card-header">
                <h2 class="text-sm font-semibold text-gray-900">Design</h2>
              </div>
              <div class="card-body space-y-4">
                <div class="grid grid-cols-2 gap-4">
                  <div>
                    <label class="form-label">Couleur de fond</label>
                    <div class="flex items-center gap-2">
                      <input type="color" name="design[colorBg]"
                        value="<%= old?.design?.colorBg || vcard?.design?.colorBg || '#f8fafc' %>"
                        x-model="colorBg"
                        class="w-10 h-10 rounded-lg border border-gray-200 cursor-pointer p-0.5">
                      <input type="text" class="form-input font-mono text-sm" x-model="colorBg">
                    </div>
                  </div>
                  <div>
                    <label class="form-label">Couleur carte</label>
                    <div class="flex items-center gap-2">
                      <input type="color" name="design[colorCard]"
                        value="<%= old?.design?.colorCard || vcard?.design?.colorCard || '#ffffff' %>"
                        x-model="colorCard"
                        class="w-10 h-10 rounded-lg border border-gray-200 cursor-pointer p-0.5">
                      <input type="text" class="form-input font-mono text-sm" x-model="colorCard">
                    </div>
                  </div>
                  <div>
                    <label class="form-label">Couleur du texte</label>
                    <div class="flex items-center gap-2">
                      <input type="color" name="design[colorText]"
                        value="<%= old?.design?.colorText || vcard?.design?.colorText || '#1f2937' %>"
                        x-model="colorText"
                        class="w-10 h-10 rounded-lg border border-gray-200 cursor-pointer p-0.5">
                      <input type="text" class="form-input font-mono text-sm" x-model="colorText">
                    </div>
                  </div>
                  <div>
                    <label class="form-label">Couleur des boutons</label>
                    <div class="flex items-center gap-2">
                      <input type="color" name="design[colorBtn]"
                        value="<%= old?.design?.colorBtn || vcard?.design?.colorBtn || '#5b6af5' %>"
                        x-model="colorBtn"
                        class="w-10 h-10 rounded-lg border border-gray-200 cursor-pointer p-0.5">
                      <input type="text" class="form-input font-mono text-sm" x-model="colorBtn">
                    </div>
                  </div>
                </div>
                <div>
                  <label class="form-label">Police</label>
                  <select name="design[fontStyle]" class="form-select" x-model="fontStyle">
                    <option value="inter" <%= (old?.design?.fontStyle || vcard?.design?.fontStyle || 'inter') === 'inter' ? 'selected' : '' %>>Inter</option>
                    <option value="poppins" <%= (old?.design?.fontStyle || vcard?.design?.fontStyle) === 'poppins' ? 'selected' : '' %>>Poppins</option>
                    <option value="montserrat" <%= (old?.design?.fontStyle || vcard?.design?.fontStyle) === 'montserrat' ? 'selected' : '' %>>Montserrat</option>
                    <option value="nunito" <%= (old?.design?.fontStyle || vcard?.design?.fontStyle) === 'nunito' ? 'selected' : '' %>>Nunito</option>
                  </select>
                </div>
              </div>
            </div>

            <!-- Section Médias -->
            <div class="card">
              <div class="card-header">
                <h2 class="text-sm font-semibold text-gray-900">Médias</h2>
              </div>
              <div class="card-body space-y-4">
                <div>
                  <label class="form-label">Logo <span class="text-gray-400 font-normal">(PNG recommandé)</span></label>
                  <% if (vcard?.mediaPaths?.logo) { %>
                  <div class="flex items-center gap-3 mb-2 p-2 bg-gray-50 rounded-lg">
                    <img src="<%= vcard.mediaPaths.logo %>" alt="Logo" class="h-8 object-contain">
                    <label class="flex items-center gap-1 text-xs text-red-600 cursor-pointer">
                      <input type="checkbox" name="removeLogo" value="true" class="w-3 h-3"> Supprimer
                    </label>
                  </div>
                  <% } %>
                  <input type="file" name="logo" accept="image/*" class="form-input text-sm file:mr-3 file:py-1 file:px-3 file:rounded file:border-0 file:text-sm file:font-medium file:bg-brand-50 file:text-brand-700 hover:file:bg-brand-100">
                </div>
                <div>
                  <label class="form-label">Photo de profil <span class="text-gray-400 font-normal">(format carré)</span></label>
                  <% if (vcard?.mediaPaths?.photo) { %>
                  <div class="flex items-center gap-3 mb-2 p-2 bg-gray-50 rounded-lg">
                    <img src="<%= vcard.mediaPaths.photo %>" alt="Photo" class="w-10 h-10 rounded-full object-cover">
                    <label class="flex items-center gap-1 text-xs text-red-600 cursor-pointer">
                      <input type="checkbox" name="removePhoto" value="true" class="w-3 h-3"> Supprimer
                    </label>
                  </div>
                  <% } %>
                  <input type="file" name="photo" accept="image/*" class="form-input text-sm file:mr-3 file:py-1 file:px-3 file:rounded file:border-0 file:text-sm file:font-medium file:bg-brand-50 file:text-brand-700 hover:file:bg-brand-100">
                </div>
                <div>
                  <label class="form-label">Image de fond <span class="text-gray-400 font-normal">(optionnel)</span></label>
                  <% if (vcard?.mediaPaths?.background) { %>
                  <div class="flex items-center gap-3 mb-2 p-2 bg-gray-50 rounded-lg">
                    <img src="<%= vcard.mediaPaths.background %>" alt="Fond" class="h-8 object-cover rounded">
                    <label class="flex items-center gap-1 text-xs text-red-600 cursor-pointer">
                      <input type="checkbox" name="removeBackground" value="true" class="w-3 h-3"> Supprimer
                    </label>
                  </div>
                  <% } %>
                  <input type="file" name="background" accept="image/*" class="form-input text-sm file:mr-3 file:py-1 file:px-3 file:rounded file:border-0 file:text-sm file:font-medium file:bg-brand-50 file:text-brand-700 hover:file:bg-brand-100">
                </div>
              </div>
            </div>

            <!-- Section Réseaux sociaux -->
            <div class="card">
              <div class="card-header">
                <h2 class="text-sm font-semibold text-gray-900">Réseaux sociaux</h2>
              </div>
              <div class="card-body space-y-3">
                <template x-for="(social, i) in socials" :key="i">
                  <div class="flex items-center gap-2">
                    <select :name="`socialLinks[${i}][type]`" x-model="social.type" class="form-select w-36 flex-shrink-0">
                      <option value="linkedin">LinkedIn</option>
                      <option value="instagram">Instagram</option>
                      <option value="facebook">Facebook</option>
                      <option value="web">Site web</option>
                      <option value="calendar">Calendrier</option>
                    </select>
                    <input type="url" :name="`socialLinks[${i}][url]`" x-model="social.url"
                      class="form-input flex-1" placeholder="https://...">
                    <button type="button" @click="removeSocial(i)"
                      class="flex-shrink-0 text-gray-400 hover:text-red-500 transition-colors p-1">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                    </button>
                  </div>
                </template>
                <button type="button" @click="addSocial()"
                  class="btn-secondary btn-sm w-full justify-center">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                  Ajouter un réseau
                </button>
              </div>
            </div>

            <!-- Section Boutons supplémentaires -->
            <div class="card">
              <div class="card-header">
                <h2 class="text-sm font-semibold text-gray-900">Boutons supplémentaires <span class="text-gray-400 font-normal text-xs">(max 3)</span></h2>
              </div>
              <div class="card-body space-y-3">
                <template x-for="(btn, i) in extraButtons" :key="i">
                  <div class="flex items-center gap-2">
                    <input type="text" :name="`extraButtons[${i}][text]`" x-model="btn.text"
                      class="form-input w-36 flex-shrink-0" placeholder="Libellé">
                    <input type="url" :name="`extraButtons[${i}][url]`" x-model="btn.url"
                      class="form-input flex-1" placeholder="https://...">
                    <button type="button" @click="removeExtraBtn(i)"
                      class="flex-shrink-0 text-gray-400 hover:text-red-500 transition-colors p-1">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                    </button>
                  </div>
                </template>
                <button type="button" @click="addExtraBtn()"
                  x-show="extraButtons.length < 3"
                  class="btn-secondary btn-sm w-full justify-center">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                  Ajouter un bouton
                </button>
              </div>
            </div>

            <!-- Actions formulaire -->
            <div class="flex items-center justify-between">
              <a href="/o/<%= currentOrg.slug %>/vcards" class="btn-secondary">Annuler</a>
              <button type="submit" class="btn-primary">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                <%= vcard ? 'Enregistrer les modifications' : 'Créer la VCard' %>
              </button>
            </div>
          </form>
        </div>

        <!-- Colonne droite : aperçu téléphone -->
        <div class="w-80 flex-shrink-0 sticky top-6">
          <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-3 text-center">Aperçu</p>
          <!-- Téléphone mockup -->
          <div class="mx-auto relative" style="width:300px;">
            <!-- Coque téléphone -->
            <div class="relative rounded-[2.5rem] border-4 border-gray-800 bg-gray-800 shadow-2xl overflow-hidden" style="min-height:580px;">
              <!-- Notch -->
              <div class="absolute top-0 left-1/2 -translate-x-1/2 w-24 h-6 bg-gray-800 rounded-b-2xl z-10"></div>
              <!-- Écran -->
              <div class="overflow-y-auto" :style="`background-color: ${colorBg}; min-height:572px; padding-top:28px;`">
                <!-- Contenu de la page -->
                <div class="px-4 pb-8">
                  <!-- Logo -->
                  <div class="flex justify-center mb-4">
                    <div class="w-20 h-12 rounded-lg bg-white/30 flex items-center justify-center">
                      <svg class="w-6 h-6 text-white/50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                    </div>
                  </div>
                  <!-- Card principale -->
                  <div class="rounded-2xl shadow-md p-5" :style="`background-color: ${colorCard};`">
                    <!-- Photo -->
                    <div x-show="showPhoto" class="flex justify-center mb-3">
                      <div class="w-20 h-20 rounded-full bg-gray-200 border-4 flex items-center justify-center" :style="`border-color: ${colorBtn};`">
                        <svg class="w-8 h-8 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                      </div>
                    </div>
                    <!-- Nom -->
                    <div x-show="showName" class="text-center mb-3">
                      <p class="font-bold text-base" :style="`color: ${colorText}; font-family: ${fontStyle}, sans-serif;`" x-text="firstName + ' ' + lastName || 'Prénom Nom'"></p>
                    </div>
                    <!-- Bouton principal -->
                    <div x-show="mainButtonText" class="mb-3">
                      <button class="w-full py-2.5 rounded-xl text-white text-sm font-semibold" :style="`background-color: ${colorBtn};`" x-text="mainButtonText"></button>
                    </div>
                    <!-- Contact -->
                    <div class="space-y-2 mb-3">
                      <div x-show="phone" class="flex items-center gap-2">
                        <div class="w-7 h-7 rounded-lg flex items-center justify-center flex-shrink-0" :style="`background-color: ${colorBtn}20;`">
                          <svg class="w-3.5 h-3.5" :style="`color: ${colorBtn};`" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                        </div>
                        <span class="text-xs" :style="`color: ${colorText};`" x-text="phone"></span>
                      </div>
                      <div x-show="contactEmail" class="flex items-center gap-2">
                        <div class="w-7 h-7 rounded-lg flex items-center justify-center flex-shrink-0" :style="`background-color: ${colorBtn}20;`">
                          <svg class="w-3.5 h-3.5" :style="`color: ${colorBtn};`" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                        </div>
                        <span class="text-xs" :style="`color: ${colorText};`" x-text="contactEmail"></span>
                      </div>
                      <div x-show="address" class="flex items-center gap-2">
                        <div class="w-7 h-7 rounded-lg flex items-center justify-center flex-shrink-0" :style="`background-color: ${colorBtn}20;`">
                          <svg class="w-3.5 h-3.5" :style="`color: ${colorBtn};`" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                        </div>
                        <span class="text-xs truncate" :style="`color: ${colorText};`" x-text="address"></span>
                      </div>
                    </div>
                    <!-- Réseaux sociaux -->
                    <div x-show="socials.filter(s=>s.url).length > 0" class="flex flex-wrap gap-2 justify-center mb-3">
                      <template x-for="(s, i) in socials.filter(s=>s.url)" :key="i">
                        <div class="w-8 h-8 rounded-lg flex items-center justify-center text-white text-xs font-bold" :style="`background-color: ${colorBtn};`" x-text="s.type[0].toUpperCase()"></div>
                      </template>
                    </div>
                    <!-- Boutons extra -->
                    <div x-show="extraButtons.filter(b=>b.text).length > 0" class="space-y-2">
                      <template x-for="(btn, i) in extraButtons.filter(b=>b.text)" :key="i">
                        <button class="w-full py-2 rounded-xl text-sm font-medium border" :style="`color: ${colorBtn}; border-color: ${colorBtn};`" x-text="btn.text"></button>
                      </template>
                    </div>
                  </div>
                  <!-- Bouton vCard download -->
                  <div x-show="showVcard" class="mt-3">
                    <button class="w-full py-2.5 rounded-xl text-sm font-medium border" :style="`color: ${colorBtn}; border-color: ${colorBtn}; background: transparent;`">
                      Télécharger le contact
                    </button>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

    </main>
  </div>
</div>
<%- include('../partials/confirm-modal') %>

<script>
function vcardForm() {
  return {
    vcName: `<%= (vcard?.name || '').replace(/`/g, '\\`') %>`,
    firstName: `<%= (vcard?.identity?.firstName || '').replace(/`/g, '\\`') %>`,
    lastName: `<%= (vcard?.identity?.lastName || '').replace(/`/g, '\\`') %>`,
    showName: <%= vcard?.identity?.showName !== false ? 'true' : 'false' %>,
    showPhoto: <%= vcard?.identity?.showPhoto !== false ? 'true' : 'false' %>,
    showVcard: <%= vcard?.showVcard !== false ? 'true' : 'false' %>,
    isPublished: <%= vcard?.isPublished ? 'true' : 'false' %>,
    phone: `<%= (vcard?.contact?.phone || '').replace(/`/g, '\\`') %>`,
    contactEmail: `<%= (vcard?.contact?.email || '').replace(/`/g, '\\`') %>`,
    address: `<%= (vcard?.contact?.address || '').replace(/`/g, '\\`') %>`,
    mainButtonText: `<%= (vcard?.contact?.mainButtonText || 'Me contacter').replace(/`/g, '\\`') %>`,
    colorBg: '<%= vcard?.design?.colorBg || "#f8fafc" %>',
    colorCard: '<%= vcard?.design?.colorCard || "#ffffff" %>',
    colorText: '<%= vcard?.design?.colorText || "#1f2937" %>',
    colorBtn: '<%= vcard?.design?.colorBtn || "#5b6af5" %>',
    fontStyle: '<%= vcard?.design?.fontStyle || "inter" %>',
    socials: <%- vcard?.socialLinks ? JSON.stringify(vcard.socialLinks) : '[]' %>,
    extraButtons: <%- vcard?.extraButtons ? JSON.stringify(vcard.extraButtons) : '[]' %>,
    addSocial() { this.socials.push({ type: 'linkedin', url: '' }); },
    removeSocial(i) { this.socials.splice(i, 1); },
    addExtraBtn() { if (this.extraButtons.length < 3) this.extraButtons.push({ text: '', url: '' }); },
    removeExtraBtn(i) { this.extraButtons.splice(i, 1); },
  };
}
</script>
<script src="/js/app.js"></script>
</body>
</html>
