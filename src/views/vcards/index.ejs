<!DOCTYPE html>
<html lang="fr" class="h-full bg-gray-100">
<head>
  <meta charset="UTF-8"><link rel="icon" href="/favicon.svg" type="image/svg+xml"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>VCards — Voilà Voilà Tools</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/app.css">
  <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.14.1/dist/cdn.min.js"></script>
  <script src="https://unpkg.com/htmx.org@2.0.0/dist/htmx.min.js"></script>
</head>
<body class="h-full" x-data="{ sidebarOpen: false }">
<div id="htmx-progress"></div>
<div class="flex h-full">
  <div x-cloak x-show="sidebarOpen" @click="sidebarOpen=false" class="fixed inset-0 bg-gray-900/50 z-20 lg:hidden"></div>
  <aside class="fixed inset-y-0 left-0 z-30 w-64 bg-white border-r border-gray-200 flex flex-col transition-transform duration-300 lg:translate-x-0 lg:static lg:flex" :class="sidebarOpen ? 'translate-x-0' : '-translate-x-full'">
    <%- include('../partials/sidebar') %>
  </aside>
  <div class="flex-1 flex flex-col min-w-0 overflow-hidden">
    <%- include('../partials/header') %>
    <main class="flex-1 overflow-y-auto p-6">
      <%- include('../partials/flash') %>

      <!-- En-tête + CTA -->
      <div class="flex items-center justify-between mb-6">
        <div>
          <h1 class="text-2xl font-bold text-gray-900">VCards</h1>
          <p class="text-sm text-gray-500 mt-0.5"><%= vcards.length %> vcard<%= vcards.length > 1 ? 's' : '' %></p>
        </div>
        <a href="/o/<%= currentOrg.slug %>/vcards/create" class="btn-primary">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
          Nouvelle VCard
        </a>
      </div>

      <% if (vcards.length === 0) { %>
      <!-- Empty state -->
      <div class="card p-12 text-center">
        <div class="w-16 h-16 bg-brand-50 rounded-full flex items-center justify-center mx-auto mb-4">
          <svg class="w-8 h-8 text-brand-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V8a2 2 0 00-2-2h-5m-4 0V5a2 2 0 114 0v1m-4 0a2 2 0 104 0m-5 8a2 2 0 100-4 2 2 0 000 4zm0 0c1.306 0 2.417.835 2.83 2M9 14a3.001 3.001 0 00-2.83 2M15 11h3m-3 4h2"/>
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-gray-900 mb-2">Aucune VCard</h3>
        <p class="text-sm text-gray-500 mb-6">Créez votre première carte de visite numérique partageable.</p>
        <a href="/o/<%= currentOrg.slug %>/vcards/create" class="btn-primary">Créer ma première VCard</a>
      </div>

      <% } else { %>
      <!-- Grille de cards -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        <% vcards.forEach(vcard => { %>
        <div class="card" id="vcard-card-<%= vcard.id %>">
          <div class="card-body">
            <!-- Header card -->
            <div class="flex items-start justify-between mb-3">
              <div class="flex items-center gap-3 min-w-0">
                <div class="w-10 h-10 rounded-xl flex-shrink-0 flex items-center justify-center text-white font-bold text-sm"
                     style="background-color: <%= vcard.design?.colorBtn || '#5b6af5' %>">
                  <%= (vcard.name || 'V')[0].toUpperCase() %>
                </div>
                <div class="min-w-0">
                  <p class="font-semibold text-gray-900 truncate"><%= vcard.name %></p>
                  <p class="text-xs text-gray-400 font-mono truncate">/<%= vcard.slug %></p>
                </div>
              </div>
              <% if (vcard.isPublished) { %>
              <span class="badge badge-green flex-shrink-0">Publié</span>
              <% } else { %>
              <span class="badge badge-gray flex-shrink-0">Brouillon</span>
              <% } %>
            </div>

            <!-- URL publique -->
            <a href="<%= appUrl %>/v/<%= currentOrg.slug %>/<%= vcard.slug %>" target="_blank"
               class="flex items-center gap-1.5 text-xs text-brand-600 hover:text-brand-700 bg-brand-50 rounded-lg px-3 py-2 mb-4 truncate group">
              <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
              <span class="truncate"><%= appUrl %>/v/<%= currentOrg.slug %>/<%= vcard.slug %></span>
            </a>

            <!-- Actions -->
            <div class="flex items-center gap-2">
              <a href="<%= appUrl %>/v/<%= currentOrg.slug %>/<%= vcard.slug %>" target="_blank"
                 class="btn-secondary btn-sm flex-1 justify-center" title="Voir la page publique">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                Voir
              </a>
              <a href="/o/<%= currentOrg.slug %>/vcards/<%= vcard.id %>/edit"
                 class="btn-secondary btn-sm flex-1 justify-center" title="Modifier">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                Modifier
              </a>
              <button
                hx-delete="/o/<%= currentOrg.slug %>/vcards/<%= vcard.id %>"
                hx-target="#vcard-card-<%= vcard.id %>"
                hx-swap="outerHTML swap:300ms"
                hx-confirm="Supprimer la VCard « <%= vcard.name %> » ?"
                class="btn-sm text-gray-400 hover:text-red-500 transition-colors border border-gray-200 rounded-lg px-2.5 py-1.5" title="Supprimer">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
              </button>
            </div>
          </div>
        </div>
        <% }) %>
      </div>
      <% } %>

    </main>
  </div>
</div>
<%- include('../partials/confirm-modal') %>
<script src="/js/app.js"></script>
</body>
</html>
